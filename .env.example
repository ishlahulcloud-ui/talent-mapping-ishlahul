# GAS deployment URL (Web App, "Execute as me", "Anyone" access).
# Leave blank and set VITE_USE_MOCK=true to run the UI on local fixtures.
VITE_GAS_URL=

# When true, dataService returns fixture data and never calls GAS.
# Use for local UI development before the backend is deployed.
VITE_USE_MOCK=true

# Google Identity Services OAuth client id (staff sign-in). Required only
# when VITE_USE_MOCK=false. Must match GIS_CLIENT_ID in the GAS Script
# Properties so the backend can verify the id_token audience.
VITE_GIS_CLIENT_ID=
